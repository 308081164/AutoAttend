{
  "name": "autoattend-vscode-plugin",
  "displayName": "AutoAttend",
  "description": "在 VSCode 中查看并编辑 AutoAttend 协作多维表格与看板",
  "version": "0.0.1",
  "publisher": "autoattend",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:autoAttend.sidebarView",
    "onCommand:autoAttend.openPanel",
    "onCommand:autoAttend.logout",
    "onCommand:autoAttend.toggleCodingTime",
    "onCommand:autoAttend.flushCodingQueue"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autoAttend.openPanel",
        "title": "AutoAttend: 打开工作台"
      },
      {
        "command": "autoAttend.logout",
        "title": "AutoAttend: 退出登录"
      },
      {
        "command": "autoAttend.toggleCodingTime",
        "title": "AutoAttend: 切换编码统计开关"
      },
      {
        "command": "autoAttend.flushCodingQueue",
        "title": "AutoAttend: 立即上报编码队列"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "autoAttend",
          "title": "AutoAttend",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "autoAttend": [
        {
          "type": "webview",
          "id": "autoAttend.sidebarView",
          "name": "协作工作台"
        }
      ]
    },
    "configuration": {
      "title": "AutoAttend",
      "properties": {
        "autoAttend.baseUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "AutoAttend 后端服务地址"
        },
        "autoAttend.codingTime.enabled": {
          "type": "boolean",
          "default": false,
          "description": "启用 WakaTime 类编码时长采集（窗口焦点 + 活动编辑器启发式），需登录并绑定协作项目"
        },
        "autoAttend.codingTime.heartbeatSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 30,
          "maximum": 120,
          "description": "在持续编辑态下，每隔多少秒切一段心跳上报"
        },
        "autoAttend.codingTime.sendFileFingerprint": {
          "type": "boolean",
          "default": false,
          "description": "是否在心跳中附带文档 URI 的 SHA-256 短指纹（默认关闭以保护隐私）"
        }
      }
    }
  },
  "scripts": {
    "compile": "npx tsc -p .",
    "watch": "npx tsc -watch -p .",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.5.4"
  }
}
