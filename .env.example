# 复制为 .env 后填写（与 docker-compose.yml 同目录）。docker compose 会自动加载本文件用于变量替换。
# 阿里云短信：登录/注册验证码（租户管理员）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
# 可选：ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com

# ---------- Penpot（快原型 Beta，docker-compose.penpot.yml）----------
# Compose 合并后所有 autoattend-* 与 penpot-* 服务在同一网络 autoattend_net（见根目录 docker-compose*.yml），
# 后端可用服务名 penpot-frontend:8080、penpot-backend:6060，无需再手工配 extra_hosts。
# 宿主机访问 Penpot Web 的端口（容器内为 80）
# PENPOT_HTTP_PORT=9001
# 浏览器打开 Penpot 工作区的公网基址（与 RPC 分离时必配）；不配则与 PENPOT_INTERNAL_URI 相同（可能只有容器内可打开）
# PENPOT_PUBLIC_URI=https://penpot.example.com
# 可选：仅后端调 RPC 的 URL（一般等于 PENPOT_INTERNAL_URI）
# PENPOT_API_BASE_URL=http://penpot-frontend:80
# 后端容器内访问 Penpot 前端的地址（勿填 AutoAttend 公网域名；须为 Docker 内 penpot-frontend 或等价反代）
# PENPOT_INTERNAL_URI=http://penpot-frontend:80
# 可选：直连 Penpot 后端 RPC（官方默认 6060）；PRIMARY 不可达或误指本应用时后端会自动再试此地址
# PENPOT_BACKEND_DIRECT_URI=http://penpot-backend:6060
# RPC 必须带 x-client（与官方前端一致）；默认 penpot-backend
# PENPOT_CLIENT_HEADER=penpot-backend
# 镜像版本，建议锁小版本号便于升级
# PENPOT_VERSION=latest
# 生产务必替换为随机串：python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# PENPOT_SECRET_KEY=
# 邮件调试 Web UI 宿主机端口（与 MinIO 控制台等避免冲突时可改）
# PENPOT_MAILCATCHER_HTTP_PORT=1080
# Penpot 2.12+ RPC 基路径为 /api/main/methods/；旧版 /api/rpc/command/。默认 auto 由后端自动探测
# PENPOT_RPC_PATH_STYLE=auto
# 后端调用 Penpot API（每租户自动开户 + 库内 Token；无需平台级 PENPOT_ACCESS_TOKEN）
# docker-compose.prod.yml 中 backend 默认 PENPOT_ENABLED=true（与 Penpot 栈一起用时）；若不想启用可显式设为 false
# PENPOT_ENABLED=true
# 租户 Penpot 注册邮箱域与密码盐（生产务必设置 PEPPER 为长随机串）
# PENPOT_TENANT_EMAIL_DOMAIN=penpot.local
# PENPOT_TENANT_CREDENTIAL_PEPPER=
# 与库内 NexusCryptoService 加密一致：租户 Penpot Token/密码密文依赖此 key；生产必须设置且勿随意更换，否则已有凭证无法解密
# NEXUS_CRYPTO_DEV_KEY=
# 可选兼容：平台级 Token 或邮箱密码（旧部署/脚本 bootstrap）
# PENPOT_ACCESS_TOKEN=
# PENPOT_EMAIL=
# PENPOT_PASSWORD=
