# 复制为 .env 后填写（与 docker-compose.yml 同目录）。docker compose 会自动加载本文件用于变量替换。
# 阿里云短信：登录/注册验证码（租户管理员）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
# 可选：ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com

# ---------- Penpot（快原型 Beta，docker-compose.penpot.yml）----------
# 宿主机访问 Penpot Web 的端口（容器内为 8080）
# PENPOT_HTTP_PORT=9001
# 浏览器打开的公开 URL（须与反代/防火墙一致；生产请改为 https://你的域名:9001 或经网关的路径）
# PENPOT_PUBLIC_URI=http://localhost:9001
# 后端容器内访问 Penpot 前端的地址（一般勿改）
# PENPOT_INTERNAL_URI=http://penpot-frontend:8080
# 镜像版本，建议锁小版本号便于升级
# PENPOT_VERSION=latest
# 生产务必替换为随机串：python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# PENPOT_SECRET_KEY=
# 邮件调试 Web UI 宿主机端口（与 MinIO 控制台等避免冲突时可改）
# PENPOT_MAILCATCHER_HTTP_PORT=1080
